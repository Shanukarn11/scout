DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=scout.example.com,127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=https://scout.example.com
DJANGO_TIME_ZONE=Asia/Kolkata
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_HSTS_SECONDS=0

DB_ENGINE=mysql
DB_NAME=scout
DB_USER=scout
DB_PASSWORD=replace-with-a-unique-database-password
DB_HOST=172.17.0.1
DB_PORT=3306
DB_CONN_MAX_AGE=60
# Must match the fixed Compose subnet grant: 'scout'@'172.19.%'.
DB_ALLOWED_HOST=172.19.%

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
LEVEL2_DEFAULT_COURSE_ID=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=ikfseason2
OSS_ENDPOINT=oss-ap-south-1.aliyuncs.com
INTERAKT_API_KEY=

SCOUT_IMAGE=ghcr.io/shanukarn11/scout-site:latest
SCOUT_HOST_PORT=8010
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
HEALTHCHECK_RETRIES=30
